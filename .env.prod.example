# .env.prod.example — variáveis de produção (copie para .env e preencha; NÃO versionar).
# Gere segredos fortes: openssl rand -hex 32

# Postgres
POSTGRES_USER=almox
POSTGRES_PASSWORD=troque-senha-forte
POSTGRES_DB=almoxarifado

# Conexões (dentro da rede do compose, host = postgres:5432)
# ATENÇÃO: a role almox_app é criada pela migration 0001 com a senha 'almox_app_dev'.
# Em produção, altere-a após migrar:  ALTER ROLE almox_app PASSWORD '...';  e reflita aqui.
MIGRATION_DATABASE_URL=postgres://almox:troque-senha-forte@postgres:5432/almoxarifado
DATABASE_URL=postgres://almox_app:troque-senha-app@postgres:5432/almoxarifado

# Auth (obrigatórios em produção)
JWT_ACCESS_SECRET=
OTP_PEPPER=
TOKEN_PEPPER=

# Providers
NOTIFICATION_PROVIDER=log        # log | evolution
PAYMENT_PROVIDER=mock            # mock | mercadopago
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
MERCADOPAGO_ACCESS_TOKEN=

# Exposição do frontend (em VPS com Traefik, use porta alta e roteie pelo painel)
FRONTEND_PORT=80
