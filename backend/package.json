{
  "name": "almoxarifado-backend",
  "version": "0.0.0",
  "private": true,
  "description": "API REST — Sistema de Gestão de Almoxarifado (SaaS multi-tenant)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts src/db/migrate.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist --packages=external",
    "start": "node dist/index.js",
    "start:migrate": "node dist/db/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "otpauth": "^9.5.1",
    "pg": "^8.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
