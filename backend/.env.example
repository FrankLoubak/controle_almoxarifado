# Backend — variáveis de ambiente (copie para .env e preencha)

# Banco de dados (Postgres) — ver docker-compose.yml
# MIGRATION_DATABASE_URL: conexão do dono (superuser) — aplica migrations/DDL.
# DATABASE_URL: conexão da aplicação (role sem privilégio, sujeita ao RLS).
MIGRATION_DATABASE_URL=postgres://almox:almox_dev@localhost:5433/almoxarifado
DATABASE_URL=postgres://almox_app:almox_app_dev@localhost:5433/almoxarifado

# Servidor
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo

# Auth / JWT (Sprint 2) — segredos e peppers OBRIGATÓRIOS em produção
JWT_ACCESS_SECRET=troque-em-producao
OTP_PEPPER=troque-em-producao
TOKEN_PEPPER=troque-em-producao
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
PREAUTH_TTL_SECONDS=120

# 2FA / OTP (Sprint 2)
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate limiting (opcional — defaults no código)
RL_LOGIN_MAX=20
RL_OTP_MAX=30

# NotificationProvider (Sprint 2) — log (mock) | evolution
NOTIFICATION_PROVIDER=log
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
N8N_WEBHOOK_URL=

# PaymentProvider (Sprint 9) — mock | mercadopago
PAYMENT_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
