# Backend — variáveis de ambiente (copie para .env e preencha)

# Banco de dados (Postgres) — ver docker-compose.yml
# MIGRATION_DATABASE_URL: conexão do dono (superuser) — aplica migrations/DDL.
# DATABASE_URL: conexão da aplicação (role sem privilégio, sujeita ao RLS).
MIGRATION_DATABASE_URL=postgres://almox:almox_dev@localhost:5433/almoxarifado
DATABASE_URL=postgres://almox_app:almox_app_dev@localhost:5433/almoxarifado

# Servidor
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo

# Auth / JWT (Sprint 2)
JWT_ACCESS_SECRET=troque-em-producao
JWT_REFRESH_SECRET=troque-em-producao
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# 2FA / OTP (Sprint 2)
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# NotificationProvider — Evolution API + n8n (Sprint 2)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
N8N_WEBHOOK_URL=

# PaymentProvider — Mercado Pago (Sprint 9)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
